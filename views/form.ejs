<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= title %></title>
    <link rel="stylesheet" href="/styles.css" />
  </head>
  <body>
    <div class="container">
      <h1><%= title %></h1>

      <form method="POST" action="/new">
        <div class="form-group">
          <label for="messageUser">Your Name:</label>
          <input type="text" id="messageUser" name="messageUser" required />
        </div>

        <div class="form-group">
          <label for="messageText">Your Message:</label>
          <textarea id="messageText" name="messageText" required></textarea>
        </div>

        <button type="submit">Post Message</button>
      </form>

      <a href="/" class="back-link">← Back to Messages</a>
    </div>
  </body>
</html>
